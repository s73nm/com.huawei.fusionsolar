{
  "id": "com.huawei.fusionsolar",
  "version": "1.0.0",
  "compatibility": ">=12.3.0",
  "runtime": "nodejs",
  "sdk": 3,
  "platforms": [
    "local"
  ],
  "brandColor": "#CF0A2C",
  "name": {
    "en": "FusionSolar Solar Manager",
    "de": "FusionSolar Solar Manager"
  },
  "description": {
    "en": "Take control of your solar energy — via Kiosk, OpenAPI or Modbus.",
    "de": "Solarenergie im Griff – via Kiosk, OpenAPI oder Modbus."
  },
  "tags": {
    "en": ["solar", "pv", "photovoltaic", "huawei", "fusionsolar", "energy", "inverter"],
    "de": ["solar", "pv", "photovoltaik", "huawei", "fusionsolar", "energie", "wechselrichter"]
  },
  "category": "energy",
  "images": {
    "small": "/assets/images/small.png",
    "large": "/assets/images/large.png",
    "xlarge": "/assets/images/xlarge.png"
  },
  "author": {
    "name": "Andi",
    "email": "andi@wirzfamily.ch"
  },
  "source": "https://github.com/andiwirz/com.huawei.fusionsolar",
  "bugs": {
    "url": "https://github.com/andiwirz/com.huawei.fusionsolar/issues"
  },
  "capabilities": {
    "huawei_status": {
      "type": "string",
      "title": { "en": "Inverter Status", "de": "Status des Wechselrichters" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false,
      "icon": "/assets/capabilities/huawei_status.svg"
    },
    "activepower_controlmode": {
      "type": "enum",
      "title": { "en": "Active Power Control Mode", "de": "Wirkleistungs-Steuermodus" },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "insights": false,
      "values": [
        { "id": "0", "title": { "en": "Unlimited", "de": "Unbegrenzt" } },
        { "id": "1", "title": { "en": "DI Active Scheduling", "de": "DI Aktive Planung" } },
        { "id": "5", "title": { "en": "Zero Power Grid Connection", "de": "Nulleinspeisung" } },
        { "id": "6", "title": { "en": "Power Limited (kW)", "de": "Leistungsbegrenzung (kW)" } },
        { "id": "7", "title": { "en": "Power Limited (%)", "de": "Leistungsbegrenzung (%)" } }
      ]
    },
    "storage_working_mode_settings": {
      "type": "enum",
      "title": { "en": "Storage Working Mode", "de": "Speicher-Betriebsmodus" },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "insights": false,
      "values": [
        { "id": "0", "title": { "en": "Adaptive", "de": "Adaptiv" } },
        { "id": "1", "title": { "en": "Fixed Charge/Discharge", "de": "Festes Laden/Entladen" } },
        { "id": "2", "title": { "en": "Maximise Self-Consumption", "de": "Eigenverbrauch maximieren" } },
        { "id": "3", "title": { "en": "Time of Use (LG)", "de": "Zeitabhängige Nutzung (LG)" } },
        { "id": "4", "title": { "en": "Fully Fed to Grid", "de": "Volleinspeisung" } },
        { "id": "5", "title": { "en": "Time of Use (LUNA2000)", "de": "Zeitabhängige Nutzung (LUNA2000)" } },
        { "id": "6", "title": { "en": "Third-party Scheduling", "de": "Drittanbieter-Steuerung" } }
      ]
    },
    "storage_force_charge_discharge": {
      "type": "enum",
      "title": { "en": "Force Charge/Discharge", "de": "Erzwungenes Laden/Entladen" },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "insights": false,
      "values": [
        { "id": "0", "title": { "en": "Stop", "de": "Stopp" } },
        { "id": "1", "title": { "en": "Charge", "de": "Laden" } },
        { "id": "2", "title": { "en": "Discharge", "de": "Entladen" } }
      ]
    },
    "storage_excess_pv_energy_use_in_tou": {
      "type": "enum",
      "title": { "en": "Excess PV Energy (TOU)", "de": "Überschuss-PV-Energie (TOU)" },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "insights": false,
      "values": [
        { "id": "0", "title": { "en": "Feed to Grid", "de": "Ins Netz einspeisen" } },
        { "id": "1", "title": { "en": "Charge Battery", "de": "Batterie laden" } }
      ]
    },
    "remote_charge_discharge_control_mode": {
      "type": "enum",
      "title": { "en": "Remote Charge/Discharge Mode", "de": "Fernsteuerung Laden/Entladen" },
      "getable": true,
      "setable": true,
      "uiComponent": "picker",
      "insights": false,
      "values": [
        { "id": "0", "title": { "en": "Local Control", "de": "Lokale Steuerung" } },
        { "id": "1", "title": { "en": "Remote: Max Self-Consumption", "de": "Fern: Max Eigenverbrauch" } },
        { "id": "2", "title": { "en": "Remote: Fully Fed to Grid", "de": "Fern: Volleinspeisung" } },
        { "id": "3", "title": { "en": "Remote: Time of Use", "de": "Fern: Zeitabhängige Nutzung" } },
        { "id": "4", "title": { "en": "Remote: AI Control", "de": "Fern: KI-Steuerung" } },
        { "id": "5", "title": { "en": "Remote: Three-party Scheduling", "de": "Fern: Drittanbieter-Steuerung" } }
      ]
    },
    "meter_power_daily": {
      "type": "number",
      "title": { "en": "Daily Energy (legacy)", "de": "Tagesertrag (veraltet)" },
      "units": "kWh",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "meter_power_cumulative": {
      "type": "number",
      "title": { "en": "Total Energy (legacy)", "de": "Gesamtertrag (veraltet)" },
      "units": "kWh",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "huawei_device_status": {
      "type": "string",
      "title": { "en": "Inverter Status (legacy)", "de": "Wechselrichterstatus (veraltet)" },
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "measure_battery_power": {
      "type": "number",
      "title": { "en": "Battery Power (legacy)", "de": "Batterieleistung (veraltet)" },
      "units": "W",
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "meter_battery_charge_today": {
      "type": "number",
      "title": { "en": "Battery Charged Today (legacy)", "de": "Heute geladen (veraltet)" },
      "units": "kWh",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "meter_battery_discharge_today": {
      "type": "number",
      "title": { "en": "Battery Discharged Today (legacy)", "de": "Heute entladen (veraltet)" },
      "units": "kWh",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "measure_power_meter": {
      "type": "number",
      "title": { "en": "Power Meter (legacy)", "de": "Leistungszähler (veraltet)" },
      "units": "W",
      "decimals": 0,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "meter_power_exported": {
      "type": "number",
      "title": { "en": "Grid Exported (legacy)", "de": "Netzeinspeisung (veraltet)" },
      "units": "kWh",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "meter_power_grid_accumulated": {
      "type": "number",
      "title": { "en": "Grid Accumulated (legacy)", "de": "Netzbezug gesamt (veraltet)" },
      "units": "kWh",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    },
    "meter_power_monthly": {
      "type": "number",
      "title": { "en": "Monthly Energy", "de": "Monatsertrag" },
      "units": "kWh",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true,
      "icon": "/assets/capabilities/meter_power.svg"
    },
    "meter_power_yearly": {
      "type": "number",
      "title": { "en": "Yearly Energy", "de": "Jahresertrag" },
      "units": "kWh",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true,
      "icon": "/assets/capabilities/meter_power.svg"
    },
    "measure_efficiency": {
      "type": "number",
      "title": { "en": "Inverter Efficiency", "de": "Wechselrichter-Wirkungsgrad" },
      "units": "%",
      "decimals": 1,
      "min": 0,
      "max": 100,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": true
    },
    "measure_frequency": {
      "type": "number",
      "title": { "en": "Grid Frequency", "de": "Netzfrequenz" },
      "units": "Hz",
      "decimals": 2,
      "getable": true,
      "setable": false,
      "uiComponent": "sensor",
      "insights": false
    }
  },
  "drivers": [
    {
      "id": "fusionsolar_kiosk",
      "name": {
        "en": "FusionSolar Plant (Kiosk)",
        "de": "FusionSolar Anlage (Kiosk)"
      },
      "class": "solarpanel",
      "platforms": ["local", "cloud"],
      "connectivity": [],
      "repair": [{ "id": "start" }],
      "energy": {
        "meterPowerExportedCapability": "meter_power"
      },
      "capabilities": [
        "measure_power",
        "meter_power",
        "meter_power.daily",
        "meter_power_monthly",
        "meter_power_yearly"
      ],
      "capabilitiesOptions": {
        "measure_power": {
          "title": { "en": "Current Power", "de": "Aktuelle Leistung" }
        },
        "meter_power": {
          "title": { "en": "Total Energy", "de": "Gesamtertrag" }
        },
        "meter_power.daily": {
          "title": { "en": "Daily Energy", "de": "Tagesgesamtertrag" }
        }
      },
      "images": {
        "small": "/drivers/fusionsolar_kiosk/assets/images/small.png",
        "large": "/drivers/fusionsolar_kiosk/assets/images/large.png",
        "xlarge": "/drivers/fusionsolar_kiosk/assets/images/xlarge.png"
      },
      "pair": [{ "id": "start" }],
      "settings": [
        {
          "id": "kiosk_url",
          "type": "text",
          "label": { "en": "Kiosk URL", "de": "Kiosk URL" },
          "value": "",
          "hint": {
            "en": "The full FusionSolar Kiosk URL ending in ?kk=...",
            "de": "Die vollständige FusionSolar Kiosk URL mit ?kk=..."
          },
          "highlight": true
        },
        {
          "id": "poll_interval",
          "type": "number",
          "label": { "en": "Update Interval", "de": "Aktualisierungsintervall" },
          "units": { "en": "minutes", "de": "Minuten" },
          "value": 10,
          "min": 5,
          "max": 60,
          "hint": {
            "en": "How often to fetch data. Huawei caches data for ~30 minutes.",
            "de": "Wie oft Daten abgerufen werden. Huawei cached Daten ~30 Minuten."
          }
        }
      ]
    },
